---
import { LiquidGlassCard } from "../ui/liquid-glass";
---

<section class="intro-stop" aria-labelledby="intro-title">
  <div class="intro-overlay">
    <LiquidGlassCard
      client:load
      draggable={false}
      blurIntensity="xl"
      glowIntensity="sm"
      shadowIntensity="sm"
      borderRadius="28px"
      className="intro-glass"
    >
      <div class="intro-card-content">
        <p class="intro-kicker">Backend Engineer at Taiwan.</p>
        <h1 id="intro-title" class="intro-title">
          I build fast, reliable systems with people in mind.
        </h1>
        <p class="intro-copy">
          I build high-performance, user-friendly applications and turn new
          technologies into practical products.
        </p>
      </div>
    </LiquidGlassCard>
  </div>
</section>

<style is:global>
  .intro-stop {
    min-height: 220vh;
    pointer-events: none;
  }

  .intro-overlay {
    position: fixed;
    inset: 0;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    padding: clamp(1.25rem, 6vw, 5rem);
    opacity: var(--intro-opacity, 0);
    pointer-events: none;
    transform: translateY(calc((1 - var(--intro-opacity, 0)) * 10px));
    transition:
      opacity 0.18s linear,
      transform 0.18s linear;
  }

  .intro-glass {
    width: min(34rem, 100%);
    overflow: hidden;
    background: color-mix(in srgb, var(--color-paper) 24%, transparent);
    pointer-events: auto;
  }

  .intro-card-content {
    position: relative;
    z-index: 30;
    padding: clamp(1.35rem, 4vw, 2.45rem);
    color: var(--color-ink);
  }

  .intro-kicker {
    margin: 0;
    font-size: clamp(0.72rem, 1.8vw, 0.82rem);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--color-ink) 66%, transparent);
  }

  .intro-title {
    max-width: 11ch;
    margin: 0.85rem 0 0;
    font-size: clamp(2.45rem, 7vw, 4.65rem);
    font-weight: 360;
    line-height: 0.94;
    letter-spacing: -0.03em;
    text-wrap: balance;
  }

  .intro-copy {
    max-width: 30rem;
    margin: 1.2rem 0 0;
    font-size: clamp(1rem, 2vw, 1.12rem);
    line-height: 1.65;
    color: color-mix(in srgb, var(--color-ink) 72%, transparent);
  }

  @media (max-width: 768px) {
    .intro-overlay {
      align-items: flex-start;
      justify-content: center;
      padding: 14vh 1rem 1rem;
    }

    .intro-glass {
      width: min(100%, 24rem);
    }

    .intro-title {
      max-width: 10ch;
      font-size: clamp(2.35rem, 13vw, 3.5rem);
    }

    .intro-copy {
      font-size: 0.98rem;
      line-height: 1.62;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .intro-overlay {
      transition: none;
    }
  }
</style>
