---
import { LiquidGlassCard } from "../ui/liquid-glass";
---

<section
  class="intro-stop pointer-events-none min-h-[220vh]"
  aria-labelledby="intro-title"
>
  <div
    class="fixed inset-0 z-2 flex items-center justify-end p-[clamp(1.25rem,6vw,5rem)] opacity-(--intro-opacity,0) pointer-events-none transition-[opacity,transform] duration-180 ease-linear translate-y-[calc((1-var(--intro-opacity,0))*10px)] motion-reduce:transition-none max-md:items-start max-md:justify-center max-md:pt-[14vh] max-md:px-4 max-md:pb-4"
  >
    <LiquidGlassCard
      client:load
      draggable={false}
      blurIntensity="xl"
      glowIntensity="sm"
      shadowIntensity="sm"
      borderRadius="28px"
      className="w-[min(34rem,100%)] overflow-hidden bg-[color-mix(in_srgb,var(--color-paper)_24%,transparent)] pointer-events-auto max-md:w-[min(100%,24rem)]"
    >
      <div class="relative z-30 p-[clamp(1.35rem,4vw,2.45rem)] text-ink">
        <p
          class="m-0 text-[clamp(0.72rem,1.8vw,0.82rem)] tracking-[0.18em] uppercase text-[color-mix(in_srgb,var(--color-ink)_66%,transparent)]"
        >
          Backend Engineer in Taiwan.
        </p>
        <h1
          id="intro-title"
          class="mt-[0.85rem] mb-0 max-w-[11ch] text-[clamp(2.45rem,7vw,4.65rem)] font-[360] leading-[0.94] tracking-[-0.03em] text-balance max-md:max-w-[10ch] max-md:text-[clamp(2.35rem,13vw,3.5rem)]"
        >
          I build systems people can rely on.
        </h1>
        <p
          class="mt-[1.2rem] mb-0 max-w-120 text-[clamp(1rem,2vw,1.12rem)] leading-[1.65] text-[color-mix(in_srgb,var(--color-ink)_72%,transparent)] max-md:text-[0.98rem] max-md:leading-[1.62]"
        >
          Backend-focused — performance, clarity, and turning new tech into
          things that actually ship.
        </p>
      </div>
    </LiquidGlassCard>
  </div>
</section>
